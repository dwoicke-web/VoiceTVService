# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Database
DATABASE_PATH=./voicetv.db

# YouTube TV API
YOUTUBE_TV_API_KEY=your_youtube_tv_api_key_here

# Peacock API
PEACOCK_API_KEY=your_peacock_api_key_here
PEACOCK_API_SECRET=your_peacock_api_secret_here

# ESPN+ API
ESPN_PLUS_API_KEY=your_espn_plus_api_key_here

# Amazon Prime Video API
AMAZON_PRIME_API_KEY=your_amazon_prime_api_key_here

# HBO Max API
HBO_MAX_API_KEY=your_hbo_max_api_key_here

# Samsung SmartThings
SAMSUNG_SMARTTHINGS_TOKEN=your_smartthings_token_here
SAMSUNG_SMARTTHINGS_DEVICE_ID=your_big_screen_device_id_here

# Google Cloud Speech-to-Text
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id

# Sonos
SONOS_HOUSEHOLD_ID=your_sonos_household_id
SONOS_API_KEY=your_sonos_api_key_here

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
